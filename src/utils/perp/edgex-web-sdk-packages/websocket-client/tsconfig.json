{
  "extends": "@edgex/typescript-config/internal-package.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ES6", "ESNext"],
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "paths": {
      "~/*": ["src/*"]
    }
  },
  "include": ["."],
  "exclude": ["dist", "build", "node_modules"]
}
