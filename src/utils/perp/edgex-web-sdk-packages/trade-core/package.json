{
  "name": "@edgex/trade-core",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./domain": {
      "types": "./src/domain/index.ts",
      "import": "./src/domain/index.ts",
      "default": "./src/domain/index.ts"
    },
    "./application": {
      "types": "./src/application/index.ts",
      "import": "./src/application/index.ts",
      "default": "./src/application/index.ts"
    },
    "./infrastructure": {
      "types": "./src/infrastructure/index.ts",
      "import": "./src/infrastructure/index.ts",
      "default": "./src/infrastructure/index.ts"
    },
    "./calculator": {
      "types": "./src/domain/calculator/index.ts",
      "import": "./src/domain/calculator/index.ts",
      "default": "./src/domain/calculator/index.ts"
    }
  },
  "typesVersions": {
    "*": {
      "domain": [
        "./src/domain/index.ts"
      ],
      "application": [
        "./src/application/index.ts"
      ],
      "infrastructure": [
        "./src/infrastructure/index.ts"
      ],
      "calculator": [
        "./src/domain/calculator/index.ts"
      ],
      "*": [
        "./src/index.ts"
      ]
    }
  },
  "scripts": {
    "lint": "eslint \"**/*.ts*\"",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@edgex/typescript-config": "workspace:*"
  },
  "dependencies": {
    "@edgex/http-client": "workspace:*",
    "@edgex/trade-libs": "workspace:*",
    "@edgex/types": "workspace:*",
    "@edgex/utils": "workspace:*",
    "axios": "^1.6.2",
    "bignumber.js": "^9.3.1"
  }
}
